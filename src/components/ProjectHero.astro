---
/*
 * ProjectHero.astro — the card-motif hero for a single project page.
 *
 * A large "hero card" dealt onto the page at a slight angle: eyebrow (repo
 * slug), project title, energy-badge tag chips and a primary "View on GitHub"
 * action. Styled from the PORT-7 design system so it reads as the biggest card
 * in the deck.
 */
import TagChip from './TagChip.astro';
import Button from './Button.astro';

export interface Props {
  title: string;
  slug: string;
  tags: string[];
  repoUrl: string;
  accent?: 'orange' | 'pine' | 'sky';
}

const { title, slug, tags, repoUrl, accent = 'orange' } = Astro.props;
---

<header class="hero-card" style={`--hero-accent: var(--c-${accent});`}>
  <div class="hero-card__face">
    <p class="hero-card__eyebrow">
      <span class="hero-card__pip" aria-hidden="true"></span>
      {slug}
    </p>
    <h1 class="hero-card__title">{title}</h1>

    {
      tags.length > 0 && (
        <ul class="hero-card__tags chip-row" role="list" aria-label="Tags">
          {tags.map((tag) => (
            <li>
              <TagChip label={tag} />
            </li>
          ))}
        </ul>
      )
    }

    <div class="hero-card__actions">
      <Button href={repoUrl} variant="primary" size="lg">
        <svg
          class="hero-card__gh"
          viewBox="0 0 16 16"
          width="18"
          height="18"
          aria-hidden="true"
          fill="currentColor"
        >
          <path
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"
          ></path>
        </svg>
        View on GitHub
      </Button>
    </div>
  </div>
</header>

<style>
  .hero-card {
    perspective: 1200px;
    margin-block: var(--space-lg) var(--space-2xl);
  }

  .hero-card__face {
    position: relative;
    overflow: hidden;
    padding: clamp(var(--space-lg), 5vw, var(--space-2xl));
    background: var(--c-paper-raised);
    border: var(--border-hair);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    /* Dealt down at a slight hand-placed angle. */
    transform: rotate(-0.6deg);
  }

  /* Accent rail across the top edge — the card's "energy type". */
  .hero-card__face::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 5px;
    background: var(--hero-accent);
    opacity: 0.9;
  }

  /* Faint diagonal gloss so the paper catches light. */
  .hero-card__face::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(
      160deg,
      rgb(255 255 255 / 0.45) 0%,
      rgb(255 255 255 / 0) 34%
    );
  }

  .hero-card__eyebrow {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-family: var(--font-mono);
    font-size: var(--fs-100);
    letter-spacing: var(--tracking-mono);
    text-transform: uppercase;
    color: var(--c-ink-muted);
  }
  .hero-card__pip {
    width: 0.55em;
    height: 0.55em;
    border-radius: 50%;
    background: var(--hero-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--hero-accent) 22%, transparent);
  }

  .hero-card__title {
    position: relative;
    margin-top: var(--space-sm);
    max-width: 20ch;
  }

  .hero-card__tags {
    position: relative;
    margin-top: var(--space-md);
  }

  .hero-card__actions {
    position: relative;
    margin-top: var(--space-lg);
  }
  .hero-card__gh {
    flex: none;
  }

  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2xs);
    padding: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-card__face {
      transform: none;
    }
  }
</style>
