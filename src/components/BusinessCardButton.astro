---
/*
 * BusinessCardButton.astro — the floating "card in your pocket" button.
 *
 * Rendered site-wide by Base.astro; whether it shows on a given page is
 * decided server-side from src/lib/businessCardButton.ts (declared-pages
 * config). Clicking it opens the 3D business card (PORT-19's
 * mountBusinessCard) in a full-viewport overlay; the Three.js chunk loads
 * only on first open. The button floats above all page content with its own
 * shadow so it reads as sitting on the screen rather than in the page.
 */
import { showBusinessCardButton } from '../lib/businessCardButton';

const visible = showBusinessCardButton(Astro.url.pathname);
---

{
  visible && (
    <div data-card-fab-root>
      <button
        class="card-fab"
        type="button"
        aria-label="View my business card"
        aria-haspopup="dialog"
        data-card-fab
      >
        <svg viewBox="0 0 28 28" aria-hidden="true" fill="none">
          <g transform="rotate(-12 14 14)">
            <rect x="5" y="8.5" width="18" height="11.5" rx="2.2" fill="var(--c-paper)" stroke="var(--c-ink)" stroke-width="1.4" />
            <rect x="5" y="8.5" width="18" height="2.6" rx="1.3" fill="var(--c-orange)" />
            <line x1="8" y1="14.6" x2="17" y2="14.6" stroke="var(--c-ink)" stroke-width="1.3" stroke-linecap="round" />
            <line x1="8" y1="17.2" x2="13.5" y2="17.2" stroke="var(--c-ink-muted)" stroke-width="1.1" stroke-linecap="round" />
          </g>
        </svg>
      </button>

      <div class="card-fab-overlay" data-card-fab-overlay hidden role="dialog" aria-modal="true" aria-label="Business card">
        <div class="card-fab-overlay__scene" data-card-fab-scene />
        <button class="card-fab-overlay__close" type="button" aria-label="Close business card" data-card-fab-close>
          ×
        </button>
        <p class="card-fab-overlay__hint">drag to flip · esc to close</p>
      </div>
    </div>
  )
}

<style>
  .card-fab {
    position: fixed;
    right: clamp(1rem, 3vw, 2rem);
    bottom: clamp(1rem, 3vw, 2rem);
    z-index: var(--z-float);
    width: 3.4rem;
    height: 3.4rem;
    border-radius: 50%;
    border: var(--border-hair);
    background: var(--c-paper-raised);
    display: grid;
    place-items: center;
    cursor: pointer;
    /* Deep, layered shadow — the button should look like it hovers over the
       screen itself, not like an element embedded in the page. */
    box-shadow:
      0 1px 2px rgba(30, 36, 34, 0.18),
      0 6px 16px rgba(30, 36, 34, 0.22),
      0 16px 40px rgba(30, 36, 34, 0.18);
    transition:
      transform var(--dur-fast) var(--ease-spring),
      box-shadow var(--dur-fast) var(--ease-out);
  }

  .card-fab svg {
    width: 1.75rem;
    height: 1.75rem;
  }

  .card-fab:hover,
  .card-fab:focus-visible {
    transform: translateY(-3px) rotate(3deg);
    box-shadow:
      0 2px 3px rgba(30, 36, 34, 0.16),
      0 10px 24px rgba(30, 36, 34, 0.24),
      0 24px 56px rgba(30, 36, 34, 0.2);
  }

  .card-fab:active {
    transform: translateY(-1px) scale(0.97);
  }

  .card-fab-overlay {
    position: fixed;
    inset: 0;
    z-index: var(--z-float);
    background: color-mix(in srgb, var(--c-ink) 42%, transparent);
    backdrop-filter: blur(7px);
  }

  .card-fab-overlay__scene {
    position: absolute;
    inset: 0;
  }

  .card-fab-overlay__close {
    position: absolute;
    top: clamp(0.9rem, 3vw, 1.6rem);
    right: clamp(0.9rem, 3vw, 1.6rem);
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 50%;
    border: var(--border-hair);
    background: var(--c-paper-raised);
    color: var(--c-ink);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 4px 14px rgba(30, 36, 34, 0.3);
  }

  .card-fab-overlay__hint {
    position: absolute;
    bottom: 1.1rem;
    left: 50%;
    transform: translateX(-50%);
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-paper);
    opacity: 0.75;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .card-fab,
    .card-fab:hover,
    .card-fab:focus-visible,
    .card-fab:active {
      transition: none;
      transform: none;
    }
  }
</style>

<script>
  import type { BusinessCardHandle } from '../scripts/businessCard';

  const root = document.querySelector('[data-card-fab-root]');
  if (root) {
    const fab = root.querySelector<HTMLButtonElement>('[data-card-fab]')!;
    const overlay = root.querySelector<HTMLElement>('[data-card-fab-overlay]')!;
    const scene = root.querySelector<HTMLElement>('[data-card-fab-scene]')!;
    const closeBtn = root.querySelector<HTMLButtonElement>('[data-card-fab-close]')!;

    let handle: BusinessCardHandle | null = null;
    let opening = false;

    async function open() {
      if (opening || !overlay.hidden) return;
      opening = true;
      overlay.hidden = false; // scene container needs layout before mounting
      document.body.style.overflow = 'hidden';
      try {
        const { mountBusinessCard } = await import('../scripts/businessCard');
        handle = await mountBusinessCard(scene);
      } finally {
        opening = false;
      }
      closeBtn.focus();
    }

    function close() {
      if (overlay.hidden) return;
      handle?.destroy();
      handle = null;
      scene.replaceChildren();
      overlay.hidden = true;
      document.body.style.overflow = '';
      fab.focus();
    }

    fab.addEventListener('click', open);
    closeBtn.addEventListener('click', close);
    overlay.addEventListener('pointerdown', (e) => {
      // Backdrop click closes; drags that start on the scene belong to the card.
      if (e.target === overlay) close();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') close();
    });
  }
</script>
